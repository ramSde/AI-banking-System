<?xml version="1.0" encoding="UTF-8"?>
<!-- ══════════════════════════════════════════════════════════════════════
API Gateway — logback-spring.xml
Structured JSON logging configuration for production observability
Ref: https://docs.spring.io/spring-boot/docs/current/reference/html/features.html#features.logging
══════════════════════════════════════════════════════════════════════ -->
<configuration>
    
    <!-- ── PROPERTIES ──────────────────────────────────────────────────── -->
    <springProfile name="!prod">
        <property name="LOG_LEVEL" value="INFO"/>
        <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level [%X{traceId:-},%X{spanId:-}] %logger{36} - %msg%n"/>
    </springProfile>
    
    <springProfile name="prod">
        <property name="LOG_LEVEL" value="WARN"/>
    </springProfile>

    <!-- ── CONSOLE APPENDER (Development) ──────────────────────────────── -->
    <springProfile name="!prod">
        <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>
    </springProfile>

    <!-- ── JSON APPENDER (Production) ───────────────────────────────────── -->
    <springProfile name="prod,staging">
        <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <timestamp>
                        <timeZone>UTC</timeZone>
                        <pattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</pattern>
                    </timestamp>
                    <logLevel/>
                    <loggerName/>
                    <message/>
                    <mdc/>
                    <arguments/>
                    <stackTrace/>
                    <pattern>
                        <pattern>
                            {
                                "service": "api-gateway",
                                "environment": "${SPRING_PROFILES_ACTIVE:-unknown}",
                                "traceId": "%X{traceId:-}",
                                "spanId": "%X{spanId:-}",
                                "userId": "%X{userId:-}",
                                "requestId": "%X{requestId:-}",
                                "thread": "%thread"
                            }
                        </pattern>
                    </pattern>
                </providers>
            </encoder>
        </appender>
    </springProfile>

    <!-- ── FILE APPENDER (Optional for local debugging) ────────────────── -->
    <springProfile name="dev">
        <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/api-gateway.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
                <fileNamePattern>logs/api-gateway.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                    <maxFileSize>100MB</maxFileSize>
                </timeBasedFileNamingAndTriggeringPolicy>
                <maxHistory>30</maxHistory>
                <totalSizeCap>3GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
                <charset>UTF-8</charset>
            </encoder>
        </appender>
    </springProfile>

    <!-- ── ASYNC APPENDER (Performance) ─────────────────────────────────── -->
    <springProfile name="prod,staging">
        <appender name="ASYNC_JSON" class="ch.qos.logback.classic.AsyncAppender">
            <appender-ref ref="JSON_CONSOLE"/>
            <queueSize>1000</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <includeCallerData>false</includeCallerData>
        </appender>
    </springProfile>

    <!-- ── LOGGERS ─────────────────────────────────────────────────────── -->
    
    <!-- Banking Gateway Application Logs -->
    <logger name="com.banking.gateway" level="INFO" additivity="false">
        <springProfile name="!prod">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </springProfile>
        <springProfile name="prod,staging">
            <appender-ref ref="ASYNC_JSON"/>
        </springProfile>
    </logger>

    <!-- Spring Cloud Gateway Framework -->
    <logger name="org.springframework.cloud.gateway" level="INFO" additivity="false">
        <springProfile name="!prod">
            <appender-ref ref="CONSOLE"/>
        </springProfile>
        <springProfile name="prod,staging">
            <appender-ref ref="ASYNC_JSON"/>
        </springProfile>
    </logger>

    <!-- Spring Security -->
    <logger name="org.springframework.security" level="INFO" additivity="false">
        <springProfile name="!prod">
            <appender-ref ref="CONSOLE"/>
        </springProfile>
        <springProfile name="prod,staging">
            <appender-ref ref="ASYNC_JSON"/>
        </springProfile>
    </logger>

    <!-- Redis/Lettuce (Reduced verbosity) -->
    <logger name="io.lettuce" level="WARN" additivity="false">
        <springProfile name="!prod">
            <appender-ref ref="CONSOLE"/>
        </springProfile>
        <springProfile name="prod,staging">
            <appender-ref ref="ASYNC_JSON"/>
        </springProfile>
    </logger>

    <!-- Reactor Netty (Reduced verbosity) -->
    <logger name="reactor.netty" level="WARN" additivity="false">
        <springProfile name="!prod">
            <appender-ref ref="CONSOLE"/>
        </springProfile>
        <springProfile name="prod,staging">
            <appender-ref ref="ASYNC_JSON"/>
        </springProfile>
    </logger>

    <!-- Circuit Breaker Events -->
    <logger name="io.github.resilience4j" level="INFO" additivity="false">
        <springProfile name="!prod">
            <appender-ref ref="CONSOLE"/>
        </springProfile>
        <springProfile name="prod,staging">
            <appender-ref ref="ASYNC_JSON"/>
        </springProfile>
    </logger>

    <!-- Root Logger -->
    <root level="${LOG_LEVEL}">
        <springProfile name="!prod">
            <appender-ref ref="CONSOLE"/>
        </springProfile>
        <springProfile name="prod,staging">
            <appender-ref ref="ASYNC_JSON"/>
        </springProfile>
    </root>

</configuration>