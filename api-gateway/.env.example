# ══════════════════════════════════════════════════════════════════════
# API Gateway Environment Variables
# Copy this file to .env and update values for local development
# NEVER commit .env file to source control
# ══════════════════════════════════════════════════════════════════════

# ── SPRING CONFIGURATION ─────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── SERVER CONFIGURATION ─────────────────────────────────────────────
SERVER_PORT=8080
MANAGEMENT_PORT=8081

# ── REDIS CONFIGURATION ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_CONNECT_TIMEOUT_MS=2000
REDIS_COMMAND_TIMEOUT_MS=3000
REDIS_POOL_MAX_ACTIVE=20
REDIS_POOL_MAX_IDLE=10
REDIS_POOL_MIN_IDLE=2
REDIS_POOL_MAX_WAIT_MS=3000
REDIS_SHUTDOWN_TIMEOUT_MS=2000

# ── JWT CONFIGURATION ────────────────────────────────────────────────
# RSA public key in PEM format (replace with actual key)
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA4f5wg5l2hKsTeNem/V41\nfGnJm6gOdrj8ym3rFkEjWT2btf06kkstX2LvAjYdgGnI8Ej2BpmfciHlMa8sc4VQ\nkOKvjgdHBmGHqmM5dcgKxYWtLVHZ6z/LKnZyuGBrBBYklJGdO6z1xWxJw4ej2UcN\nlXxyFn6vNjvQoaq30cINhw4f2VdF9yxqHcauHOobwuIM3fRZ6s/iiPPFRTAcrbBY\nuqBInrT3A/sczRxaJuDrLNuqoF4uGxiX+zM9XYn2br/iDo05jK6oOTu5WSOCxQKo\ngnNjKAEHNziV+y8CLWEUBtxCRczfN7WIwVBd7YYP2oNnMkXzBMO0QP2VF2lWT2kF\nQIDAQAB\n-----END PUBLIC KEY-----"
JWT_ISSUER=banking-platform
JWT_AUDIENCE=banking-api

# ── RATE LIMITING CONFIGURATION ──────────────────────────────────────
RATE_LIMIT_PER_USER=100
RATE_LIMIT_PER_IP=200
RATE_LIMIT_WINDOW_SECONDS=60

# ── CORS CONFIGURATION ───────────────────────────────────────────────
CORS_ALLOWED_ORIGIN_1=http://localhost:3000
CORS_MAX_AGE_SECONDS=3600

# ── DOWNSTREAM SERVICES ──────────────────────────────────────────────
IDENTITY_SERVICE_URL=http://localhost:8082
USER_SERVICE_URL=http://localhost:8083
ACCOUNT_SERVICE_URL=http://localhost:8084
TRANSACTION_SERVICE_URL=http://localhost:8085
FRAUD_SERVICE_URL=http://localhost:8086
AUDIT_SERVICE_URL=http://localhost:8087
NOTIFICATION_SERVICE_URL=http://localhost:8088
CHAT_SERVICE_URL=http://localhost:8089
AI_ORCHESTRATION_SERVICE_URL=http://localhost:8090
DOCUMENT_INGESTION_SERVICE_URL=http://localhost:8091
ANALYTICS_SERVICE_URL=http://localhost:8092
STATEMENT_SERVICE_URL=http://localhost:8093

# ── GATEWAY HTTP CLIENT ──────────────────────────────────────────────
GATEWAY_HTTP_CONNECT_TIMEOUT_MS=5000
GATEWAY_HTTP_RESPONSE_TIMEOUT_MS=30000
GATEWAY_HTTP_POOL_MAX_CONNECTIONS=500
GATEWAY_HTTP_POOL_MAX_IDLE_TIME_MS=20000

# ── SERVER COMPRESSION ───────────────────────────────────────────────
SERVER_COMPRESSION_MIN_SIZE=1024

# ── SERVER NETTY ─────────────────────────────────────────────────────
SERVER_NETTY_CONNECTION_TIMEOUT_MS=10000
SERVER_NETTY_IDLE_TIMEOUT_MS=60000

# ── HEALTH CHECKS ────────────────────────────────────────────────────
HEALTH_SHOW_DETAILS=always

# ── LOGGING ──────────────────────────────────────────────────────────
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_GATEWAY=DEBUG
LOG_LEVEL_SCG=DEBUG
LOG_LEVEL_LETTUCE=INFO
LOG_LEVEL_NETTY=INFO

# ── TRACING ──────────────────────────────────────────────────────────
TRACING_SAMPLING_PROBABILITY=1.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces