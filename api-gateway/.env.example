# Server Configuration
SERVER_PORT=8080
SERVER_CONNECTION_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=60s

# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# Gateway Configuration
GATEWAY_CONNECT_TIMEOUT=5000
GATEWAY_RESPONSE_TIMEOUT=30s
GATEWAY_MAX_CONNECTIONS=500
GATEWAY_MAX_IDLE_TIME=30s

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=5000ms
REDIS_POOL_MAX_ACTIVE=20
REDIS_POOL_MAX_IDLE=10
REDIS_POOL_MIN_IDLE=5
REDIS_POOL_MAX_WAIT=2000ms
REDIS_SHUTDOWN_TIMEOUT=100ms

# JWT Configuration
# Path to public key file for JWT verification (RS256)
JWT_PUBLIC_KEY_LOCATION=classpath:public-key.pem
# Or provide the public key directly as a string (base64 encoded)
JWT_PUBLIC_KEY=
JWT_ISSUER_URI=http://localhost:8081
JWT_ISSUER=banking-platform
JWT_AUDIENCE=banking-api

# Rate Limiting Configuration
RATE_LIMIT_ENABLED=true
# Requests per minute per authenticated user
RATE_LIMIT_PER_USER=100
# Requests per minute per IP address
RATE_LIMIT_PER_IP=200
# Time window in seconds for rate limiting
RATE_LIMIT_WINDOW_SIZE=60

# Logging Configuration
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_GATEWAY=DEBUG
LOG_LEVEL_SECURITY=DEBUG
LOG_LEVEL_REDIS=INFO

# Health Check Configuration
HEALTH_SHOW_DETAILS=when-authorized

# Tracing Configuration
TRACING_SAMPLING_PROBABILITY=1.0
OTLP_ENDPOINT=http://localhost:4317

# Microservice URIs - Identity & Security
IDENTITY_SERVICE_URI=http://localhost:8081
OTP_SERVICE_URI=http://localhost:8082
MFA_SERVICE_URI=http://localhost:8083
RISK_AUTH_SERVICE_URI=http://localhost:8084

# Microservice URIs - User Context
DEVICE_INTELLIGENCE_SERVICE_URI=http://localhost:8085
USER_SERVICE_URI=http://localhost:8086

# Microservice URIs - Core Banking
ACCOUNT_SERVICE_URI=http://localhost:8087
TRANSACTION_SERVICE_URI=http://localhost:8088

# Microservice URIs - Safety
FRAUD_DETECTION_SERVICE_URI=http://localhost:8089
AUDIT_SERVICE_URI=http://localhost:8090

# Microservice URIs - Communication
NOTIFICATION_SERVICE_URI=http://localhost:8091

# Microservice URIs - AI Infrastructure
DOCUMENT_INGESTION_SERVICE_URI=http://localhost:8092
RAG_PIPELINE_SERVICE_URI=http://localhost:8093

# Microservice URIs - AI Intelligence
AI_ORCHESTRATION_SERVICE_URI=http://localhost:8094
AI_INSIGHT_SERVICE_URI=http://localhost:8095

# Microservice URIs - Multimodal Interaction
CHAT_SERVICE_URI=http://localhost:8096
VISION_PROCESSING_SERVICE_URI=http://localhost:8097
SPEECH_TO_TEXT_SERVICE_URI=http://localhost:8098
TEXT_TO_SPEECH_SERVICE_URI=http://localhost:8099

# Microservice URIs - User Experience
STATEMENT_SERVICE_URI=http://localhost:8100
ADMIN_DASHBOARD_SERVICE_URI=http://localhost:8101

# Microservice URIs - Financial Intelligence
TRANSACTION_CATEGORIZATION_SERVICE_URI=http://localhost:8102
ANALYTICS_SERVICE_URI=http://localhost:8103
BUDGET_SERVICE_URI=http://localhost:8104
SEARCH_SERVICE_URI=http://localhost:8105
EXPORT_SERVICE_URI=http://localhost:8106
DASHBOARD_AGGREGATION_SERVICE_URI=http://localhost:8107

# Microservice URIs - Bank-Grade Systems
RECONCILIATION_SERVICE_URI=http://localhost:8108
BACKOFFICE_SERVICE_URI=http://localhost:8109

# Microservice URIs - Additional Services
MULTI_LANGUAGE_SERVICE_URI=http://localhost:8110
