# ══════════════════════════════════════════════════════════════════════
# API Gateway — Environment Variables (.env.example)
# Copy to .env and customize for local development
# NEVER commit .env to source control — add to .gitignore
# ══════════════════════════════════════════════════════════════════════

# ── SPRING PROFILE ────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── SERVER CONFIGURATION ──────────────────────────────────────────────
SERVER_PORT=8080
MANAGEMENT_PORT=8081

# ── REDIS CONFIGURATION ───────────────────────────────────────────────
# Description: Redis connection for rate limiting and caching
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_CONNECT_TIMEOUT_MS=2000
REDIS_COMMAND_TIMEOUT_MS=3000
REDIS_POOL_MAX_ACTIVE=20
REDIS_POOL_MAX_IDLE=10
REDIS_POOL_MIN_IDLE=2
REDIS_POOL_MAX_WAIT_MS=3000

# ── JWT CONFIGURATION ─────────────────────────────────────────────────
# Description: RSA public key for JWT validation (PEM format)
# Example: Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA4f5wg5l2hKsTeNem/V41\nfGnJm6gOdrj8ym3rFkEjWT2btf06yzRtVy4pv+Q2jdkdyVQ+6XvIIlVtc9+5VgLI\nxVHrQOHNZmrYGAMY9+5xGfeNUROnsHhNz2CaHdNdkiVDdV9lEcww5GeLvDRHQwLI\n-----END PUBLIC KEY-----"
JWT_ISSUER=banking-platform-dev
JWT_AUDIENCE=banking-api-dev

# ── RATE LIMITING ─────────────────────────────────────────────────────
# Description: Rate limiting configuration (requests per minute)
RATE_LIMIT_PER_USER=1000
RATE_LIMIT_PER_IP=2000
RATE_LIMIT_WINDOW_SECONDS=60

# ── CORS CONFIGURATION ────────────────────────────────────────────────
# Description: Cross-Origin Resource Sharing allowed origins
CORS_ALLOWED_ORIGIN_1=http://localhost:3000
CORS_MAX_AGE_SECONDS=3600

# ── DOWNSTREAM SERVICES ───────────────────────────────────────────────
# Description: URLs for downstream microservices
IDENTITY_SERVICE_URL=http://localhost:8082
USER_SERVICE_URL=http://localhost:8083
ACCOUNT_SERVICE_URL=http://localhost:8084
TRANSACTION_SERVICE_URL=http://localhost:8085
FRAUD_SERVICE_URL=http://localhost:8086
AUDIT_SERVICE_URL=http://localhost:8087
NOTIFICATION_SERVICE_URL=http://localhost:8088
CHAT_SERVICE_URL=http://localhost:8089
AI_ORCHESTRATION_SERVICE_URL=http://localhost:8090
DOCUMENT_INGESTION_SERVICE_URL=http://localhost:8091
ANALYTICS_SERVICE_URL=http://localhost:8092
STATEMENT_SERVICE_URL=http://localhost:8093

# ── GATEWAY HTTP CLIENT ───────────────────────────────────────────────
# Description: HTTP client timeouts and connection pool settings
GATEWAY_HTTP_CONNECT_TIMEOUT_MS=5000
GATEWAY_HTTP_RESPONSE_TIMEOUT_MS=30000
GATEWAY_HTTP_POOL_MAX_CONNECTIONS=500
GATEWAY_HTTP_POOL_MAX_IDLE_TIME_MS=20000

# ── ACTUATOR CONFIGURATION ────────────────────────────────────────────
# Description: Health check and metrics configuration
HEALTH_SHOW_DETAILS=always

# ── TRACING CONFIGURATION ─────────────────────────────────────────────
# Description: OpenTelemetry distributed tracing
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
TRACING_SAMPLING_PROBABILITY=1.0

# ── LOGGING LEVELS ────────────────────────────────────────────────────
# Description: Log level configuration per package
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_GATEWAY=DEBUG
LOG_LEVEL_SCG=DEBUG
LOG_LEVEL_LETTUCE=INFO
LOG_LEVEL_NETTY=INFO

# ── CIRCUIT BREAKER ───────────────────────────────────────────────────
# Description: Resilience4j circuit breaker configuration
CIRCUIT_BREAKER_FAILURE_RATE=50
CIRCUIT_BREAKER_WAIT_DURATION=30s
CIRCUIT_BREAKER_HALF_OPEN_CALLS=5
CIRCUIT_BREAKER_SLIDING_WINDOW=10
CIRCUIT_BREAKER_MIN_CALLS=5

# ── ENVIRONMENT METADATA ──────────────────────────────────────────────
# Description: Environment identification for metrics and logging
ENVIRONMENT=dev