# Spring Profile
# Description: Active Spring profile (dev, staging, prod)
# Example: dev
SPRING_PROFILES_ACTIVE=dev

# Database Configuration
# Description: PostgreSQL database host
# Example: localhost
DB_HOST=localhost

# Description: PostgreSQL database port
# Example: 5432
DB_PORT=5432

# Description: PostgreSQL database name
# Example: audit_db
DB_NAME=audit_db

# Description: PostgreSQL database username
# Example: admin
DB_USERNAME=admin

# Description: PostgreSQL database password
# Example: admin
DB_PASSWORD=admin

# Description: Enable SSL for database connection (true/false)
# Example: false
DB_SSL=false

# Description: Maximum database connection pool size
# Example: 20
DB_POOL_MAX_SIZE=20

# Description: Minimum idle database connections
# Example: 5
DB_POOL_MIN_IDLE=5

# Description: Database connection timeout in milliseconds
# Example: 30000
DB_CONNECTION_TIMEOUT=30000

# Description: Database connection idle timeout in milliseconds
# Example: 600000
DB_IDLE_TIMEOUT=600000

# Description: Database connection max lifetime in milliseconds
# Example: 1800000
DB_MAX_LIFETIME=1800000

# Kafka Configuration
# Description: Kafka bootstrap servers (comma-separated)
# Example: localhost:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Description: Kafka consumer group ID
# Example: banking-audit-service-consumer-group
KAFKA_CONSUMER_GROUP=banking-audit-service-consumer-group

# Description: Kafka auto offset reset strategy (earliest, latest, none)
# Example: earliest
KAFKA_AUTO_OFFSET_RESET=earliest

# Description: Maximum number of records per poll
# Example: 100
KAFKA_MAX_POLL_RECORDS=100

# Description: Maximum poll interval in milliseconds
# Example: 300000
KAFKA_MAX_POLL_INTERVAL=300000

# Description: Maximum Kafka request size in bytes
# Example: 10485760
KAFKA_MAX_REQUEST_SIZE=10485760

# Description: Kafka listener concurrency (number of consumer threads)
# Example: 3
KAFKA_LISTENER_CONCURRENCY=3

# Description: Kafka security protocol (PLAINTEXT, SASL_SSL, etc.)
# Example: PLAINTEXT
KAFKA_SECURITY_PROTOCOL=PLAINTEXT

# Description: Kafka SASL mechanism (PLAIN, SCRAM-SHA-256, etc.)
# Example: PLAIN
KAFKA_SASL_MECHANISM=PLAIN

# Description: Kafka SASL JAAS configuration
# Example: org.apache.kafka.common.security.plain.PlainLoginModule required username="user" password="pass";
KAFKA_SASL_JAAS_CONFIG=

# Server Configuration
# Description: Server port
# Example: 8090
SERVER_PORT=8090

# Description: Maximum Tomcat threads
# Example: 200
TOMCAT_THREADS_MAX=200

# Description: Minimum spare Tomcat threads
# Example: 10
TOMCAT_THREADS_MIN_SPARE=10

# Description: Tomcat accept count
# Example: 100
TOMCAT_ACCEPT_COUNT=100

# File Upload Configuration
# Description: Maximum file upload size
# Example: 10MB
MAX_FILE_SIZE=10MB

# Description: Maximum request size
# Example: 15MB
MAX_REQUEST_SIZE=15MB

# JWT Configuration
# Description: JWT secret key (minimum 256 bits)
# Example: your-256-bit-secret-key-change-this-in-production-environment
JWT_SECRET=your-256-bit-secret-key-change-this-in-production-environment

# Description: JWT expiration time in milliseconds
# Example: 900000 (15 minutes)
JWT_EXPIRATION=900000

# Audit Configuration
# Description: Audit event retention period in days (7 years = 2555 days)
# Example: 2555
AUDIT_RETENTION_DAYS=2555

# Description: Maximum number of results for audit queries
# Example: 1000
AUDIT_QUERY_MAX_RESULTS=1000

# Description: Enable table partitioning for audit events (true/false)
# Example: true
AUDIT_PARTITION_ENABLED=true

# Description: Partition interval in months
# Example: 3
AUDIT_PARTITION_INTERVAL_MONTHS=3

# Logging Configuration
# Description: Root logging level (TRACE, DEBUG, INFO, WARN, ERROR)
# Example: INFO
LOG_LEVEL_ROOT=INFO

# Description: Application logging level
# Example: DEBUG
LOG_LEVEL_APP=DEBUG

# Description: Spring Web logging level
# Example: INFO
LOG_LEVEL_SPRING_WEB=INFO

# Description: Spring Security logging level
# Example: INFO
LOG_LEVEL_SPRING_SECURITY=INFO

# Description: Kafka logging level
# Example: INFO
LOG_LEVEL_KAFKA=INFO

# Description: Hibernate SQL logging level
# Example: INFO
LOG_LEVEL_HIBERNATE_SQL=INFO

# Description: Hibernate SQL binder logging level
# Example: INFO
LOG_LEVEL_HIBERNATE_BINDER=INFO

# JPA Configuration
# Description: Show SQL queries (true/false)
# Example: false
JPA_SHOW_SQL=false

# Management Configuration
# Description: Health endpoint detail level (always, when-authorized, never)
# Example: when-authorized
HEALTH_SHOW_DETAILS=when-authorized

# Description: Distributed tracing sampling probability (0.0 to 1.0)
# Example: 1.0
TRACING_SAMPLING_PROBABILITY=1.0

# Swagger Configuration
# Description: Enable Swagger UI (true/false)
# Example: true
SWAGGER_ENABLED=true
