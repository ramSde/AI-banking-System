# ============================================
# OTP & MFA SERVICE - ENVIRONMENT VARIABLES
# ============================================

# Server Configuration
SERVER_PORT=8082
SPRING_PROFILES_ACTIVE=dev

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=otp_db
DB_USERNAME=admin
DB_PASSWORD=admin
DB_POOL_SIZE=20
DB_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_POOL_MAX_ACTIVE=20
REDIS_POOL_MAX_IDLE=10
REDIS_POOL_MIN_IDLE=5
REDIS_POOL_MAX_WAIT=2000

# OTP Configuration
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_PER_USER=5
OTP_RATE_LIMIT_WINDOW_SECONDS=300

# TOTP Configuration
TOTP_ISSUER=BankingPlatform
TOTP_PERIOD_SECONDS=30
TOTP_DIGITS=6
TOTP_ALGORITHM=HmacSHA1
TOTP_TIME_STEP_TOLERANCE=1

# Backup Codes Configuration
BACKUP_CODE_LENGTH=12
BACKUP_CODE_COUNT=8

# BCrypt Configuration
BCRYPT_STRENGTH=12

# JWT Configuration (for service authentication)
JWT_PUBLIC_KEY_PATH=/keys/public_key.pem
JWT_ISSUER=banking-identity-service

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_RETRIES=3
KAFKA_PRODUCER_ENABLE_IDEMPOTENCE=true

# Kafka Topics
KAFKA_TOPIC_MFA_ENROLLED=banking.otp.mfa-enrolled
KAFKA_TOPIC_OTP_VERIFIED=banking.otp.otp-verified
KAFKA_TOPIC_BACKUP_CODE_USED=banking.otp.backup-code-used

# Notification Service (for SMS/Email OTP)
NOTIFICATION_SERVICE_URL=http://localhost:8090/api/v1/notifications
NOTIFICATION_SERVICE_TIMEOUT=5000

# Actuator Configuration
MANAGEMENT_PORT=8082
MANAGEMENT_ENDPOINTS_ENABLED=true

# Logging Configuration
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_BANKING=DEBUG
LOGGING_FILE_PATH=/var/log/otp-service

# OpenTelemetry Configuration
OTEL_SERVICE_NAME=otp-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_TRACES_SAMPLER=always_on

# Prometheus Configuration
PROMETHEUS_ENABLED=true
