# Server Configuration
SERVER_PORT=8012
SPRING_PROFILES_ACTIVE=dev

# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/banking_documents?autoReconnect=true&useSSL=false&characterEncoding=utf8
DATABASE_USERNAME=admin
DATABASE_PASSWORD=admin

# HikariCP Configuration
HIKARI_MAX_POOL_SIZE=20
HIKARI_MIN_IDLE=5
HIKARI_CONNECTION_TIMEOUT=30000
HIKARI_IDLE_TIMEOUT=600000
HIKARI_MAX_LIFETIME=1800000

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2000
REDIS_POOL_MAX_ACTIVE=8
REDIS_POOL_MAX_IDLE=8
REDIS_POOL_MIN_IDLE=2
REDIS_POOL_MAX_WAIT=2000

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=banking-document-ingestion-consumer-group
KAFKA_PRODUCER_RETRIES=3
KAFKA_MAX_REQUEST_SIZE=10485760

# Kafka Topics
KAFKA_TOPIC_UPLOAD_REQUESTED=banking.documents.upload-requested
KAFKA_TOPIC_PROCESSED=banking.documents.processed
KAFKA_TOPIC_PROCESSING_FAILED=banking.documents.processing-failed
KAFKA_TOPIC_DLQ=banking.documents.upload-requested.dlq
KAFKA_TOPIC_RETRY=banking.documents.upload-requested.retry

# Kafka SSL Configuration (Production only)
KAFKA_SSL_TRUSTSTORE_LOCATION=/path/to/truststore.jks
KAFKA_SSL_TRUSTSTORE_PASSWORD=changeit
KAFKA_SSL_KEYSTORE_LOCATION=/path/to/keystore.jks
KAFKA_SSL_KEYSTORE_PASSWORD=changeit

# MinIO Configuration
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password
MINIO_BUCKET_NAME=banking-documents
MINIO_SECURE=false

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4

# ChromaDB Configuration
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=banking_documents

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-minimum-256-bits-required-for-hs256
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Document Processing Configuration
DOCUMENT_CHUNK_SIZE=1000
DOCUMENT_CHUNK_OVERLAP=200
DOCUMENT_MAX_FILE_SIZE_MB=10
DOCUMENT_ALLOWED_MIME_TYPES=application/pdf,image/png,image/jpeg,image/jpg
TESSERACT_DATA_PATH=/usr/share/tesseract-ocr/4.00/tessdata
TESSERACT_LANGUAGE=eng

# Multipart Configuration
MULTIPART_MAX_FILE_SIZE=10MB
MULTIPART_MAX_REQUEST_SIZE=15MB

# Async Configuration
ASYNC_CORE_POOL_SIZE=10
ASYNC_MAX_POOL_SIZE=50
ASYNC_QUEUE_CAPACITY=100
ASYNC_THREAD_NAME_PREFIX=async-document-

# Tomcat Configuration
TOMCAT_THREADS_MAX=200
TOMCAT_THREADS_MIN_SPARE=10
TOMCAT_ACCEPT_COUNT=100

# JPA Configuration
JPA_SHOW_SQL=false

# Actuator Configuration
ACTUATOR_HEALTH_SHOW_DETAILS=when-authorized

# Tracing Configuration
TRACING_SAMPLING_PROBABILITY=1.0

# Logging Configuration
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
LOG_LEVEL_SPRING_WEB=INFO
LOG_LEVEL_SPRING_SECURITY=INFO
LOG_LEVEL_KAFKA=INFO
LOG_LEVEL_HIBERNATE_SQL=INFO
LOG_LEVEL_HIBERNATE_BINDER=INFO
