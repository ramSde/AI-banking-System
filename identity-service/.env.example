# ══════════════════════════════════════════════════════════════════════
# Identity Service — Environment Variables Reference
# Copy this file to .env and fill in actual values for local development
# ══════════════════════════════════════════════════════════════════════

# ── SPRING PROFILE ────────────────────────────────────────────────────
# Options: dev, staging, prod
SPRING_PROFILES_ACTIVE=dev

# ── DATABASE (PostgreSQL) ─────────────────────────────────────────────
# PostgreSQL host (e.g., localhost, postgres-service.namespace.svc.cluster.local)
DB_HOST=localhost
# PostgreSQL port (default: 5432)
DB_PORT=5432
# Database name for identity service
DB_NAME=identity_db
# Database username
DB_USERNAME=admin
# Database password
DB_PASSWORD=admin
# Use SSL for database connection (true for prod, false for dev)
DB_USE_SSL=false
# HikariCP pool settings
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000
DB_LEAK_DETECTION_THRESHOLD=60000

# ── REDIS ─────────────────────────────────────────────────────────────
# Redis host (e.g., localhost, redis-service.namespace.svc.cluster.local)
REDIS_HOST=localhost
# Redis port (default: 6379)
REDIS_PORT=6379
# Redis password (leave empty for no auth in dev)
REDIS_PASSWORD=
# Redis database index (0-15)
REDIS_DATABASE=0
# Redis connection timeouts
REDIS_CONNECT_TIMEOUT=2000ms
REDIS_TIMEOUT=3000ms
# Redis connection pool settings
REDIS_POOL_MAX_ACTIVE=20
REDIS_POOL_MAX_IDLE=10
REDIS_POOL_MIN_IDLE=2
REDIS_POOL_MAX_WAIT=3000ms
REDIS_SHUTDOWN_TIMEOUT=2000ms

# ── KAFKA ─────────────────────────────────────────────────────────────
# Kafka bootstrap servers (comma-separated list)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# Kafka producer settings
KAFKA_PRODUCER_RETRIES=2147483647
KAFKA_MAX_REQUEST_SIZE=10485760
KAFKA_LINGER_MS=10
KAFKA_BATCH_SIZE=32768
# Kafka security (for staging/prod)
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_JAAS_CONFIG=

# ── SERVER ────────────────────────────────────────────────────────────
# Application HTTP port
SERVER_PORT=8082
# Management/actuator port
MANAGEMENT_PORT=8083
# Response compression minimum size (bytes)
SERVER_COMPRESSION_MIN_SIZE=1024
# Tomcat thread pool settings
TOMCAT_MAX_THREADS=200
TOMCAT_MIN_SPARE_THREADS=10
TOMCAT_ACCEPT_COUNT=100
TOMCAT_CONNECTION_TIMEOUT=20000

# ── JWT CONFIGURATION ─────────────────────────────────────────────────
# RSA private key for signing JWT tokens (PEM format, base64 encoded or multiline)
# Generate with: openssl genrsa -out private_key.pem 2048
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQDh/nCDmXaEqxN4\n16b9XjV8acmbqA52uPzKbesWQSNZPZu1/TrLNG1XLim/5DaN2R3JVD7pe8giVW1z\n37lWAsjFUetA4c1mathYAxj37nEZ941RE6eweE3PYJod012SJUN1X2URzDDkZ4u8\nNEdDAsI=\n-----END PRIVATE KEY-----

# RSA public key for validating JWT tokens (PEM format, base64 encoded or multiline)
# Extract from private key: openssl rsa -in private_key.pem -pubout -out public_key.pem
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA4f5wg5l2hKsTeNem/V41\nfGnJm6gOdrj8ym3rFkEjWT2btf06yzRtVy4pv+Q2jdkdyVQ+6XvIIlVtc9+5VgLI\nxVHrQOHNZmrYGAMY9+5xGfeNUROnsHhNz2CaHdNdkiVDdV9lEcww5GeLvDRHQwLI\n-----END PUBLIC KEY-----

# JWT issuer claim (identifies who issued the token)
JWT_ISSUER=banking-platform
# JWT audience claim (identifies who the token is intended for)
JWT_AUDIENCE=banking-api
# Access token time-to-live in minutes (recommended: 15)
JWT_ACCESS_TOKEN_TTL=15
# Refresh token time-to-live in days (recommended: 7)
JWT_REFRESH_TOKEN_TTL=7

# ── PASSWORD POLICY ───────────────────────────────────────────────────
# BCrypt strength (cost factor: 10-14 recommended, higher = more secure but slower)
PASSWORD_BCRYPT_STRENGTH=12
# Minimum password length
PASSWORD_MIN_LENGTH=8
# Require at least one uppercase letter
PASSWORD_REQUIRE_UPPERCASE=true
# Require at least one lowercase letter
PASSWORD_REQUIRE_LOWERCASE=true
# Require at least one digit
PASSWORD_REQUIRE_DIGIT=true
# Require at least one special character
PASSWORD_REQUIRE_SPECIAL=true

# ── SECURITY SETTINGS ─────────────────────────────────────────────────
# Maximum failed login attempts before account lockout
MAX_LOGIN_ATTEMPTS=5
# Account lockout duration in minutes after max attempts exceeded
LOCKOUT_DURATION_MINUTES=30

# ── ACTUATOR / HEALTH ─────────────────────────────────────────────────
# Health endpoint detail level: always, when-authorized, never
HEALTH_SHOW_DETAILS=when-authorized

# ── LOGGING ───────────────────────────────────────────────────────────
# Root log level: TRACE, DEBUG, INFO, WARN, ERROR
LOG_LEVEL_ROOT=INFO
# Identity service log level
LOG_LEVEL_IDENTITY=INFO
# Spring Security log level
LOG_LEVEL_SECURITY=INFO
# Kafka log level
LOG_LEVEL_KAFKA=WARN
# Hibernate log level
LOG_LEVEL_HIBERNATE=WARN
# SQL query log level
LOG_LEVEL_SQL=WARN
# SQL parameter binding log level
LOG_LEVEL_SQL_PARAMS=WARN

# ── DISTRIBUTED TRACING ───────────────────────────────────────────────
# OpenTelemetry trace sampling probability (0.0 to 1.0)
TRACING_SAMPLING_PROBABILITY=1.0
# OTLP exporter endpoint (Jaeger, Tempo, etc.)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# ── HIBERNATE TUNING ──────────────────────────────────────────────────
# JDBC batch size for bulk inserts/updates
HIBERNATE_BATCH_SIZE=20
# JDBC fetch size for result sets
HIBERNATE_FETCH_SIZE=50
