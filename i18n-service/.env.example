# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# Server Configuration
SERVER_PORT=8087

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/i18n_db
DB_USERNAME=admin
DB_PASSWORD=admin
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# JPA Configuration
JPA_SHOW_SQL=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2000
REDIS_POOL_MAX_ACTIVE=8
REDIS_POOL_MAX_IDLE=8
REDIS_POOL_MIN_IDLE=2
REDIS_POOL_MAX_WAIT=2000

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=i18n-service-consumer-group

# File Upload Configuration
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=15MB

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-change-this-in-production-use-strong-random-key
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000
JWT_ISSUER_URI=http://localhost:8081

# Tomcat Configuration
TOMCAT_THREADS_MAX=200
TOMCAT_THREADS_MIN_SPARE=10
TOMCAT_ACCEPT_COUNT=100
TOMCAT_MAX_CONNECTIONS=8192

# Logging Configuration
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SPRING_WEB=INFO
LOG_LEVEL_SPRING_SECURITY=INFO
LOG_LEVEL_HIBERNATE_SQL=DEBUG
LOG_LEVEL_HIBERNATE_BINDER=TRACE

# SpringDoc Configuration
SPRINGDOC_ENABLED=true
SWAGGER_UI_ENABLED=true

# I18n Configuration
I18N_DEFAULT_LOCALE=en
I18N_SUPPORTED_LOCALES=en,es,fr,de,hi,ar,zh
I18N_CACHE_TTL=3600
I18N_FALLBACK_TO_DEFAULT=true
I18N_AUTO_TRANSLATE_MISSING=false

# Translation API Configuration (Optional - for auto-translation)
TRANSLATION_API_ENABLED=false
TRANSLATION_API_PROVIDER=google
TRANSLATION_API_KEY=
TRANSLATION_API_TIMEOUT=30

# Tracing Configuration
TRACING_SAMPLING_PROBABILITY=1.0
