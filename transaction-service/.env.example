# Server Configuration
SERVER_PORT=8087

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/transaction_db
DB_USERNAME=admin
DB_PASSWORD=admin
DB_POOL_SIZE=30
DB_MIN_IDLE=10

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_POOL_MAX_ACTIVE=30
REDIS_POOL_MAX_IDLE=15
REDIS_POOL_MIN_IDLE=5

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=transaction-service-consumer-group

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-change-this-in-production-environment-must-be-long-enough

# Transaction Service Configuration
TRANSACTION_REFERENCE_PREFIX=TXN
TRANSACTION_IDEMPOTENCY_TTL_HOURS=24
TRANSACTION_MAX_AMOUNT=1000000.00
TRANSACTION_DAILY_LIMIT_USER=50000.00
TRANSACTION_HOLD_EXPIRY_HOURS=72

# Account Service Integration
ACCOUNT_SERVICE_URL=http://localhost:8086/api
ACCOUNT_SERVICE_TIMEOUT_SECONDS=10

# Observability
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_BANKING=DEBUG
