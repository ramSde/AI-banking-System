# Server Configuration
SERVER_PORT=8086

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/account_db
DB_USERNAME=admin
DB_PASSWORD=admin
DB_POOL_SIZE=20
DB_MIN_IDLE=5

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_POOL_MAX_ACTIVE=20
REDIS_POOL_MAX_IDLE=10
REDIS_POOL_MIN_IDLE=5

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=account-service-consumer-group

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-change-this-in-production-environment-must-be-long-enough

# Account Service Configuration
ACCOUNT_CACHE_BALANCE_TTL=5
ACCOUNT_CACHE_DETAILS_TTL=15
ACCOUNT_NUMBER_PREFIX=ACC
ACCOUNT_IBAN_COUNTRY_CODE=US
ACCOUNT_IBAN_BANK_CODE=BANK
ACCOUNT_DEFAULT_CURRENCY=USD
ACCOUNT_MIN_BALANCE_SAVINGS=100.00
ACCOUNT_MIN_BALANCE_CHECKING=0.00
ACCOUNT_MAX_ACCOUNTS_PER_USER=10

# Observability
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_BANKING=DEBUG
