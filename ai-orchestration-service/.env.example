# Server Configuration
SERVER_PORT=8014
SPRING_PROFILES_ACTIVE=dev

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_orchestration_db
DB_USERNAME=admin
DB_PASSWORD=admin

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-use-256-bit-key

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL_PRIMARY=gpt-4
OPENAI_MODEL_SECONDARY=gpt-3.5-turbo
OPENAI_TIMEOUT=60000

# Anthropic Configuration
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-3-sonnet-20240229
ANTHROPIC_TIMEOUT=60000

# Ollama Configuration (Local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
OLLAMA_TIMEOUT=120000

# AI Orchestration Configuration
AI_PRIMARY_PROVIDER=openai
AI_FALLBACK_ENABLED=true
AI_FALLBACK_CHAIN=openai,anthropic,ollama
AI_MAX_RETRIES=3
AI_RETRY_DELAY_MS=1000

# Cost Control Configuration
AI_BUDGET_ENFORCEMENT=true
AI_DEFAULT_DAILY_BUDGET_USD=10.00
AI_DEFAULT_MONTHLY_BUDGET_USD=300.00
AI_COST_ALERT_THRESHOLD=0.8

# Quota Configuration
AI_QUOTA_ENFORCEMENT=true
AI_FREE_TIER_DAILY_TOKENS=10000
AI_BASIC_TIER_DAILY_TOKENS=50000
AI_PREMIUM_TIER_DAILY_TOKENS=200000
AI_ENTERPRISE_TIER_DAILY_TOKENS=-1

# Rate Limiting Configuration
AI_RATE_LIMIT_ENABLED=true
AI_RATE_LIMIT_PER_MINUTE=60
AI_RATE_LIMIT_PER_HOUR=1000
AI_RATE_LIMIT_PER_DAY=10000

# Model Pricing (USD per 1K tokens)
OPENAI_GPT4_INPUT_PRICE=0.03
OPENAI_GPT4_OUTPUT_PRICE=0.06
OPENAI_GPT35_INPUT_PRICE=0.0015
OPENAI_GPT35_OUTPUT_PRICE=0.002
ANTHROPIC_CLAUDE_INPUT_PRICE=0.008
ANTHROPIC_CLAUDE_OUTPUT_PRICE=0.024
OLLAMA_INPUT_PRICE=0.0
OLLAMA_OUTPUT_PRICE=0.0

# Logging Configuration
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
