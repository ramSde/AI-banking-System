# Server Configuration
SERVER_PORT=8093

# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_pipeline_db
DB_USERNAME=admin
DB_PASSWORD=admin

# HikariCP Configuration
HIKARI_MAX_POOL_SIZE=20
HIKARI_MIN_IDLE=5
HIKARI_CONNECTION_TIMEOUT=30000
HIKARI_IDLE_TIMEOUT=600000
HIKARI_MAX_LIFETIME=1800000

# JPA Configuration
JPA_SHOW_SQL=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=5000ms
REDIS_POOL_MAX_ACTIVE=20
REDIS_POOL_MAX_IDLE=10
REDIS_POOL_MIN_IDLE=5
REDIS_POOL_MAX_WAIT=2000ms

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=banking-rag-pipeline-consumer-group
KAFKA_PRODUCER_RETRIES=2147483647
KAFKA_MAX_REQUEST_SIZE=10485760

# Kafka Topics
KAFKA_TOPIC_RAG_QUERY_REQUESTED=banking.rag.query-requested
KAFKA_TOPIC_RAG_QUERY_COMPLETED=banking.rag.query-completed
KAFKA_TOPIC_RAG_QUERY_FAILED=banking.rag.query-failed
KAFKA_TOPIC_RAG_CACHE_HIT=banking.rag.cache-hit
KAFKA_TOPIC_RAG_CACHE_MISS=banking.rag.cache-miss

# Tomcat Configuration
TOMCAT_THREADS_MAX=200
TOMCAT_THREADS_MIN_SPARE=10
TOMCAT_ACCEPT_COUNT=100
TOMCAT_CONNECTION_TIMEOUT=20000

# Multipart Configuration
MULTIPART_MAX_FILE_SIZE=10MB
MULTIPART_MAX_REQUEST_SIZE=15MB

# Health Check Configuration
HEALTH_SHOW_DETAILS=when-authorized

# Tracing Configuration
TRACING_SAMPLING_PROBABILITY=1.0
OTLP_ENDPOINT=http://localhost:4317

# Logging Configuration
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SPRING_WEB=INFO
LOG_LEVEL_SPRING_SECURITY=INFO
LOG_LEVEL_HIBERNATE_SQL=DEBUG
LOG_LEVEL_HIBERNATE_BINDER=TRACE

# ChromaDB Configuration
CHROMADB_URL=http://localhost:8000
CHROMADB_COLLECTION=banking_documents
CHROMADB_TIMEOUT=30000

# RAG Retrieval Configuration
RAG_MAX_RESULTS=10
RAG_SIMILARITY_THRESHOLD=0.7
RAG_RERANK_ENABLED=true
RAG_RERANK_TOP_K=5

# RAG Context Configuration
RAG_CONTEXT_MAX_TOKENS=4000
RAG_CONTEXT_OVERLAP_TOKENS=200

# RAG Cache Configuration
RAG_CACHE_ENABLED=true
RAG_CACHE_TTL=3600
RAG_CACHE_SIMILARITY_THRESHOLD=0.95

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT=60000
