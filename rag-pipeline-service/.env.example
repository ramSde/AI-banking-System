# Server Configuration
SERVER_PORT=8013
SPRING_PROFILES_ACTIVE=dev

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_pipeline_db
DB_USERNAME=admin
DB_PASSWORD=admin

# HikariCP Configuration
HIKARI_MAX_POOL_SIZE=20
HIKARI_MIN_IDLE=5
HIKARI_CONNECTION_TIMEOUT=30000
HIKARI_IDLE_TIMEOUT=600000
HIKARI_MAX_LIFETIME=1800000

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2000
REDIS_POOL_MAX_ACTIVE=20
REDIS_POOL_MAX_IDLE=10
REDIS_POOL_MIN_IDLE=5
REDIS_POOL_MAX_WAIT=2000

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=rag-pipeline-consumer-group
KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest
KAFKA_PRODUCER_RETRIES=3

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# ChromaDB Configuration
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
CHROMADB_COLLECTION=banking_documents

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-use-256-bit-key
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# RAG Configuration
RAG_TOP_K=10
RAG_SIMILARITY_THRESHOLD=0.7
RAG_MAX_RESULTS=20
RAG_RERANKING_ENABLED=true
RAG_RERANKING_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAG_RERANKING_TOP_N=5
RAG_MAX_CONTEXT_TOKENS=4000
RAG_OVERLAP_TOKENS=200
RAG_INCLUDE_SOURCES=true

# Semantic Cache Configuration
RAG_CACHE_ENABLED=true
RAG_CACHE_TTL=3600
RAG_CACHE_SIMILARITY_THRESHOLD=0.95
RAG_CACHE_MAX_ENTRIES=10000

# Tomcat Configuration
TOMCAT_THREADS_MAX=200
TOMCAT_THREADS_MIN_SPARE=10
TOMCAT_ACCEPT_COUNT=100
TOMCAT_CONNECTION_TIMEOUT=20000

# Multipart Configuration
MULTIPART_MAX_FILE_SIZE=10MB
MULTIPART_MAX_REQUEST_SIZE=15MB

# Cache Configuration
CACHE_TTL=3600000

# Actuator Configuration
ACTUATOR_HEALTH_SHOW_DETAILS=when-authorized

# Tracing Configuration
TRACING_SAMPLING_PROBABILITY=1.0

# Logging Configuration
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SPRING_WEB=INFO
LOG_LEVEL_SPRING_SECURITY=INFO
LOG_LEVEL_KAFKA=INFO
LOG_LEVEL_HIBERNATE_SQL=DEBUG
LOG_LEVEL_HIBERNATE_BINDER=TRACE

# JPA Configuration
JPA_SHOW_SQL=false
