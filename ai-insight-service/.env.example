# AI Insight Service - Environment Variables

# Application
SPRING_PROFILES_ACTIVE=dev
SERVER_PORT=8080
SPRING_APPLICATION_NAME=ai-insight-service

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/banking_ai_insights
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# JPA Configuration
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=false

# Liquibase
SPRING_LIQUIBASE_ENABLED=true
SPRING_LIQUIBASE_CHANGE_LOG=classpath:db/changelog/changelog-master.xml

# HikariCP Connection Pool
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=20
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=5
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000
SPRING_DATASOURCE_HIKARI_IDLE_TIMEOUT=600000
SPRING_DATASOURCE_HIKARI_MAX_LIFETIME=1800000
SPRING_DATASOURCE_HIKARI_CONNECTION_TEST_QUERY=SELECT 1
SPRING_DATASOURCE_HIKARI_POOL_NAME=AiInsightHikariPool

# Redis Configuration
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=
SPRING_DATA_REDIS_TIMEOUT=2000ms

# Redis Pool Configuration
SPRING_DATA_REDIS_LETTUCE_POOL_MAX_ACTIVE=8
SPRING_DATA_REDIS_LETTUCE_POOL_MAX_IDLE=8
SPRING_DATA_REDIS_LETTUCE_POOL_MIN_IDLE=2
SPRING_DATA_REDIS_LETTUCE_POOL_MAX_WAIT=-1ms

# Kafka Configuration
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SPRING_KAFKA_CONSUMER_GROUP_ID=ai-insight-service-consumer-group
SPRING_KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest
SPRING_KAFKA_CONSUMER_ENABLE_AUTO_COMMIT=false
SPRING_KAFKA_PRODUCER_KEY_SERIALIZER=org.apache.kafka.common.serialization.StringSerializer
SPRING_KAFKA_PRODUCER_VALUE_SERIALIZER=org.springframework.kafka.support.serializer.JsonSerializer

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-change-this-in-production-minimum-32-characters-required
JWT_EXPIRATION_MS=900000

# AI Orchestration Service
AI_ORCHESTRATION_SERVICE_URL=http://localhost:8080/v1/ai
AI_ORCHESTRATION_SERVICE_TIMEOUT=60000

# Transaction Service
TRANSACTION_SERVICE_URL=http://localhost:8080/v1/transactions
TRANSACTION_SERVICE_TIMEOUT=30000

# Account Service
ACCOUNT_SERVICE_URL=http://localhost:8080/v1/accounts
ACCOUNT_SERVICE_TIMEOUT=30000

# User Service
USER_SERVICE_URL=http://localhost:8080/v1/users
USER_SERVICE_TIMEOUT=30000

# Insight Generation Configuration
INSIGHT_GENERATION_ENABLED=true
INSIGHT_CACHE_TTL_HOURS=24
INSIGHT_MIN_TRANSACTIONS=10
INSIGHT_MAX_TRANSACTIONS_ANALYZED=1000
INSIGHT_GENERATION_BATCH_SIZE=100

# Anomaly Detection Configuration
ANOMALY_DETECTION_ENABLED=true
ANOMALY_DETECTION_THRESHOLD=2.0
ANOMALY_DETECTION_MIN_SAMPLES=30

# Recommendation Configuration
RECOMMENDATION_ENABLED=true
RECOMMENDATION_MAX_RESULTS=10
RECOMMENDATION_CONFIDENCE_THRESHOLD=0.7

# Spending Pattern Configuration
PATTERN_ANALYSIS_ENABLED=true
PATTERN_DETECTION_MIN_OCCURRENCES=3
PATTERN_DETECTION_TIME_WINDOW_DAYS=90

# Forecast Configuration
FORECAST_ENABLED=true
FORECAST_HORIZON_DAYS=30
FORECAST_CONFIDENCE_LEVEL=0.95

# Server Configuration
SERVER_COMPRESSION_ENABLED=true
SERVER_COMPRESSION_MIN_RESPONSE_SIZE=1024
SERVER_SERVLET_CONTEXT_PATH=/api

# Tomcat Thread Configuration
SERVER_TOMCAT_THREADS_MAX=200
SERVER_TOMCAT_THREADS_MIN_SPARE=10
SERVER_TOMCAT_ACCEPT_COUNT=100

# Multipart Configuration
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=10MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=15MB

# Actuator Configuration
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,metrics,prometheus,info
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true

# Logging Configuration
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_BANKING_INSIGHT=DEBUG
LOGGING_PATTERN_CONSOLE=%d{yyyy-MM-dd HH:mm:ss} - %msg%n

# Circuit Breaker Configuration (Resilience4j)
RESILIENCE4J_CIRCUITBREAKER_INSTANCES_AI_ORCHESTRATION_FAILURE_RATE_THRESHOLD=50
RESILIENCE4J_CIRCUITBREAKER_INSTANCES_AI_ORCHESTRATION_WAIT_DURATION_IN_OPEN_STATE=30s
RESILIENCE4J_CIRCUITBREAKER_INSTANCES_AI_ORCHESTRATION_PERMITTED_NUMBER_OF_CALLS_IN_HALF_OPEN_STATE=5

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Requested-With,Idempotency-Key
CORS_MAX_AGE=3600
