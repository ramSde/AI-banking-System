# User Service - Environment Variables Example
# Copy this file to .env and update with your actual values

# Server Configuration
SERVER_PORT=8085

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/user_db?autoReconnect=true&useSSL=false&characterEncoding=utf8
DB_USERNAME=admin
DB_PASSWORD=admin

# HikariCP Configuration
HIKARI_MAX_POOL_SIZE=20
HIKARI_MIN_IDLE=5
HIKARI_CONNECTION_TIMEOUT=30000
HIKARI_IDLE_TIMEOUT=600000
HIKARI_MAX_LIFETIME=1800000

# JPA Configuration
JPA_SHOW_SQL=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2000
REDIS_POOL_MAX_ACTIVE=8
REDIS_POOL_MAX_IDLE=8
REDIS_POOL_MIN_IDLE=2
REDIS_POOL_MAX_WAIT=2000

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=user-service-consumer-group
KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_RETRIES=2147483647
KAFKA_MAX_REQUEST_SIZE=10485760

# Multipart Configuration
MULTIPART_MAX_FILE_SIZE=10MB
MULTIPART_MAX_REQUEST_SIZE=15MB

# Tomcat Configuration
TOMCAT_THREADS_MAX=200
TOMCAT_THREADS_MIN_SPARE=10
TOMCAT_ACCEPT_COUNT=100

# Actuator Configuration
ACTUATOR_HEALTH_SHOW_DETAILS=when-authorized

# Logging Configuration
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SPRING_WEB=INFO
LOG_LEVEL_SPRING_SECURITY=INFO
LOG_LEVEL_KAFKA=INFO
LOG_LEVEL_HIBERNATE_SQL=DEBUG
LOG_LEVEL_HIBERNATE_BINDER=TRACE

# Swagger Configuration
SWAGGER_ENABLED=true

# User Service Specific Configuration
# Encryption key must be exactly 32 bytes for AES-256
USER_ENCRYPTION_ALGORITHM=AES/GCM/NoPadding
USER_ENCRYPTION_KEY=change-this-32-byte-key-in-prod

# Cache TTL in minutes
USER_CACHE_PROFILE_TTL=15
USER_CACHE_PREFERENCE_TTL=30

# KYC Configuration
USER_KYC_DOC_MAX_SIZE=10
USER_KYC_EXPIRY_DAYS=365

# JWT Configuration
# Secret must be at least 256 bits (32 bytes)
JWT_SECRET=your-256-bit-secret-key-change-in-production
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Spring Profile
SPRING_PROFILES_ACTIVE=dev
