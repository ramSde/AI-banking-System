# Device Intelligence Service - Environment Variables

# Server Configuration
SERVER_PORT=8084

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/device_db?autoReconnect=true&useSSL=false&characterEncoding=utf8
DB_USERNAME=admin
DB_PASSWORD=admin

# HikariCP Configuration
HIKARI_MAX_POOL_SIZE=20
HIKARI_MIN_IDLE=5
HIKARI_CONNECTION_TIMEOUT=30000
HIKARI_IDLE_TIMEOUT=600000
HIKARI_MAX_LIFETIME=1800000

# JPA Configuration
JPA_SHOW_SQL=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2000
REDIS_POOL_MAX_ACTIVE=8
REDIS_POOL_MAX_IDLE=8
REDIS_POOL_MIN_IDLE=2
REDIS_POOL_MAX_WAIT=2000

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=device-service-consumer-group
KAFKA_CONSUMER_AUTO_OFFSET_RESET=earliest
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_RETRIES=2147483647
KAFKA_MAX_REQUEST_SIZE=10485760

# Tomcat Configuration
TOMCAT_THREADS_MAX=200
TOMCAT_THREADS_MIN_SPARE=10
TOMCAT_ACCEPT_COUNT=100

# Multipart Configuration
MULTIPART_MAX_FILE_SIZE=10MB
MULTIPART_MAX_REQUEST_SIZE=15MB

# Actuator Configuration
ACTUATOR_HEALTH_SHOW_DETAILS=when-authorized

# Logging Configuration
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SPRING_WEB=INFO
LOG_LEVEL_SPRING_SECURITY=INFO
LOG_LEVEL_KAFKA=INFO
LOG_LEVEL_HIBERNATE_SQL=DEBUG
LOG_LEVEL_HIBERNATE_BINDER=TRACE

# Swagger Configuration
SWAGGER_ENABLED=true

# Device Service Specific Configuration
DEVICE_FINGERPRINT_ALGORITHM=SHA-256
DEVICE_FINGERPRINT_SALT=banking-device-salt-2024
DEVICE_TRUST_INITIAL_SCORE=30
DEVICE_TRUST_MAX_SCORE=100
DEVICE_TRUST_MIN_SCORE=0
DEVICE_TRUST_INCREMENT=5
DEVICE_TRUST_DECREMENT=10
DEVICE_CACHE_TTL_MINUTES=5
DEVICE_ANOMALY_IMPOSSIBLE_TRAVEL_SPEED=800
DEVICE_ANOMALY_MAX_LOCATION_CHANGE=500

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-change-in-production
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Spring Profiles
SPRING_PROFILES_ACTIVE=dev
