# ============================================
# RISK-BASED AUTHENTICATION SERVICE - ENVIRONMENT VARIABLES
# ============================================

# Server Configuration
SERVER_PORT=8083
SPRING_PROFILES_ACTIVE=dev

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=risk_db
DB_USERNAME=admin
DB_PASSWORD=admin
DB_POOL_SIZE=20
DB_MIN_IDLE=5

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_POOL_MAX_ACTIVE=20

# Risk Scoring Configuration
RISK_THRESHOLD_LOW=30
RISK_THRESHOLD_MEDIUM=60
RISK_THRESHOLD_HIGH=100
RISK_CACHE_TTL_SECONDS=300

# Risk Factors Weights (0-100)
RISK_WEIGHT_NEW_DEVICE=25
RISK_WEIGHT_NEW_LOCATION=20
RISK_WEIGHT_VELOCITY=15
RISK_WEIGHT_TIME_OF_DAY=10
RISK_WEIGHT_FAILED_ATTEMPTS=30

# JWT Configuration
JWT_PUBLIC_KEY_PATH=/keys/public_key.pem
JWT_ISSUER=banking-identity-service

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=risk-service-consumer-group
KAFKA_TOPIC_LOGIN_ATTEMPTED=banking.identity.login-attempted
KAFKA_TOPIC_LOGIN_SUCCEEDED=banking.identity.login-succeeded
KAFKA_TOPIC_RISK_ASSESSMENT=banking.risk.assessment-completed
KAFKA_TOPIC_HIGH_RISK=banking.risk.high-risk-detected
KAFKA_TOPIC_MFA_REQUIRED=banking.risk.mfa-required

# External Services
OTP_SERVICE_URL=http://localhost:8082/api/v1/otp
IDENTITY_SERVICE_URL=http://localhost:8081/api/v1/auth

# Actuator Configuration
MANAGEMENT_PORT=8083

# Logging Configuration
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_BANKING=DEBUG

# OpenTelemetry Configuration
OTEL_SERVICE_NAME=risk-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
