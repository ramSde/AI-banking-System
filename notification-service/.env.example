# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=notification_db
DB_USERNAME=admin
DB_PASSWORD=admin
DB_SSL=false
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_POOL_MAX_ACTIVE=8
REDIS_POOL_MAX_IDLE=8
REDIS_POOL_MIN_IDLE=0
REDIS_POOL_MAX_WAIT=2000

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=banking-notification-service-consumer-group
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_MAX_POLL_RECORDS=100
KAFKA_MAX_POLL_INTERVAL=300000
KAFKA_MAX_REQUEST_SIZE=10485760
KAFKA_LISTENER_CONCURRENCY=3
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_JAAS_CONFIG=

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@banking.com
EMAIL_FROM_NAME=Banking Platform
EMAIL_ENABLED=true

# SMS Configuration (Twilio)
SMS_ENABLED=true
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# Push Notification Configuration (Firebase)
PUSH_ENABLED=true
PUSH_PROVIDER=fcm
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-credentials.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# Server Configuration
SERVER_PORT=8091
TOMCAT_THREADS_MAX=200
TOMCAT_THREADS_MIN_SPARE=10
TOMCAT_ACCEPT_COUNT=100

# File Upload Configuration
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=15MB

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-change-this-in-production-environment
JWT_EXPIRATION=900000

# Notification Configuration
RETRY_MAX_ATTEMPTS=3
RETRY_INITIAL_INTERVAL=1000
RETRY_MULTIPLIER=2.0
RETRY_MAX_INTERVAL=10000
RATE_LIMIT_EMAIL=50
RATE_LIMIT_SMS=10
RATE_LIMIT_PUSH=100
DEDUP_WINDOW=300

# Thymeleaf Configuration
THYMELEAF_CACHE=false

# Logging Configuration
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SPRING_WEB=INFO
LOG_LEVEL_SPRING_SECURITY=INFO
LOG_LEVEL_KAFKA=INFO
LOG_LEVEL_MAIL=INFO

# JPA Configuration
JPA_SHOW_SQL=false

# Management Configuration
HEALTH_SHOW_DETAILS=when-authorized
TRACING_SAMPLING_PROBABILITY=1.0

# Swagger Configuration
SWAGGER_ENABLED=true
