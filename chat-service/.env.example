# Spring Profile
SPRING_PROFILES_ACTIVE=dev

# Server Configuration
SERVER_PORT=8086

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/chat_db
DB_USERNAME=admin
DB_PASSWORD=admin
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=5
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000

# JPA Configuration
JPA_SHOW_SQL=false

# Liquibase Configuration
LIQUIBASE_ENABLED=true

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=2000
REDIS_POOL_MAX_ACTIVE=8
REDIS_POOL_MAX_IDLE=8
REDIS_POOL_MIN_IDLE=2
REDIS_POOL_MAX_WAIT=2000

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=chat-service-consumer-group
KAFKA_PRODUCER_RETRIES=3

# Kafka SSL Configuration (Production only)
KAFKA_TRUSTSTORE_LOCATION=/path/to/truststore.jks
KAFKA_TRUSTSTORE_PASSWORD=changeit
KAFKA_KEYSTORE_LOCATION=/path/to/keystore.jks
KAFKA_KEYSTORE_PASSWORD=changeit

# File Upload Configuration
MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=15MB

# Cache Configuration
CACHE_TTL=3600000

# Tomcat Configuration
TOMCAT_THREADS_MAX=200
TOMCAT_THREADS_MIN_SPARE=10
TOMCAT_ACCEPT_COUNT=100
TOMCAT_CONNECTION_TIMEOUT=20000

# Management & Actuator
HEALTH_SHOW_DETAILS=when-authorized

# Metrics & Tracing
TRACING_SAMPLING_PROBABILITY=1.0

# Logging Configuration
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SPRING_WEB=INFO
LOG_LEVEL_SPRING_SECURITY=INFO
LOG_LEVEL_HIBERNATE_SQL=DEBUG
LOG_LEVEL_HIBERNATE_BINDER=TRACE

# SpringDoc OpenAPI
SPRINGDOC_ENABLED=true
SWAGGER_UI_ENABLED=true

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-change-in-production-must-be-at-least-256-bits-long
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Chat Service Configuration
CHAT_MAX_HISTORY=20
CHAT_SESSION_TIMEOUT=30
CHAT_MAX_MESSAGE_LENGTH=4000
CHAT_CONTEXT_WINDOW=8000
CHAT_ENABLE_STREAMING=true
CHAT_RATE_LIMIT_MESSAGES=20
CHAT_RATE_LIMIT_HOUR=100

# AI Orchestration Service
AI_ORCHESTRATION_URL=http://ai-orchestration-service:8084/api
AI_ORCHESTRATION_CONNECT_TIMEOUT=5000
AI_ORCHESTRATION_READ_TIMEOUT=60000

# RAG Pipeline Service
RAG_PIPELINE_URL=http://rag-pipeline-service:8083/api
RAG_CONNECT_TIMEOUT=5000
RAG_READ_TIMEOUT=30000
